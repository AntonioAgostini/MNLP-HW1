def embed_batch_of_examples(batch, model):
    """
    This function is used to build the embedded version of the dataset employed
    for evaluation. By processing examples in batches and by flattening
    the candidate chunks for each batch, it reduces the number of
    calls to the model making the entire process more efficient.
    """

    # Embedding of queries
    q_embs = model.encode(batch["query"])

    # To optimize the number of times we encode data, we encode just one flatten
    # version of the candidate chunks per example. Next we recover the correct
    # list of chunks by iterating over the embeddings and slicing them.
    flat_candidates = []
    numbers_candidates = []

    # Starting from a shape [B, K] --> [B*K]
    for cands in batch["candidate_chunks"]:
        flat_candidates.extend(cands)
        numbers_candidates.append(len(cands))

    flat_cand_embs = model.encode(flat_candidates)

    cand_embs = []
    idx = 0

    # Recovering the embeddings by slicing the flattened version
    for l in numbers_candidates:
        cand_embs.append(flat_cand_embs[idx:idx+l])
        idx += l

    return {
        "q_emb": q_embs,
        "cand_embs": cand_embs,
        "answer_pos": batch["answer_pos"]
    }

def preprocess_data(model, dataset, split_name = None, batch_size = 32):

    if split_name:
      dataset = dataset[split_name]

    emb_dataset = dataset.map(
        embed_batch_of_examples,
        batched = True,
        batch_size = batch_size,
        remove_columns = dataset.column_names,
        fn_kwargs = {"model": model},
    )

    return emb_dataset

def get_rank(q_emb, cand_embs, answer_pos):

    scores = F.cosine_similarity(
        torch.tensor(q_emb, dtype=torch.float32),
        torch.tensor(cand_embs, dtype=torch.float32)
    )

    # Sort in descending order the similarity scores and retrieve
    # the index of the correct answer (the rank)
    ranked_idx = torch.argsort(scores, descending=True).tolist()
    rank = ranked_idx.index(answer_pos) + 1

    return rank

"""### **Hit@k**

Hit@k is a metric used to evaluate the accuracy of retrieval systems. It measures whether the correct answer is present among the top k chunks recommended by the system. If the relevant item (the *answer*) is found within the top k results, it's considered a **hit**.

The formula for Hit@k is:

$$Hit@k = \frac{1}{N} \sum_{i = 1}^{N} \mathbb{I}[rank_i \leq k]$$

where:
- $\mathbb{I}$ is the indicator function;
- $k$ is the size of the top ranked window within which the correct answer is considered a hit;
- $rank_i$ is the rank of the first relevant chunk for the $i$-th query.
"""

def compute_single_hit_at_k(k, q_emb, cand_embs, answer_pos):
    rank = get_rank(q_emb, cand_embs, answer_pos)

    if rank <= k:
      return 1.0

    return 0.0

def compute_hit_at_k(k, emb_dataset):
    hits = []

    # Calling the hit@k function over each query
    for example in emb_dataset:
        hit = compute_single_hit_at_k(
            k = k,
            q_emb = example["q_emb"],
            cand_embs = example["cand_embs"],
            answer_pos = example["answer_pos"],
        )

        hits.append(hit)

    return float(np.mean(hits))

def compute_multiple_hit_at_k(k_s, emb_dataset):
    values = {}

    for k in k_s:
        values[k] = compute_hit_at_k(k, emb_dataset)

    return values

"""### **MRR**

This metric assesses the effectiveness of a information retrivial system by giving higher scores to systems that rank relevant items higher. It is calculated as the average of the reciprocal ranks of the answer for a set of queries.

The formula for MRR is:

$$MRR = \frac{1}{N} \sum_{i=1}^{N} \frac{1}{rank_i}$$

where:
- $N$ is the total number of queries.
- $rank_i$ is the rank of the first relevant chunk for the $i$-th query.
"""

def compute_reciprocal_rank(q_emb, cand_embs, answer_pos):
    rank = get_rank(q_emb, cand_embs, answer_pos)

    return 1.0 / rank

def compute_mrr(emb_dataset, batch_size=32):
    reciprocal_ranks = []

    # Calling the reciprocal rank function over each query
    for example in emb_dataset:
        rr = compute_reciprocal_rank(
            q_emb = example["q_emb"],
            cand_embs = example["cand_embs"],
            answer_pos = example["answer_pos"],
        )
        reciprocal_ranks.append(rr)

    return float(np.mean(reciprocal_ranks))

