# Preparing triplets (anchor, positive, negatives)
# This function prepares the dataset to finetune the model with the sentence triplets strategy.
# For each query, it keeps the answer as positive and samples up to five random negatives.
def prepare_item(data):
    negatives = [c for c in data["candidate_chunks"] if c != data["answer"]]
    random.shuffle(negatives)
    negatives = negatives[:3]
    item = {
        "anchor": data["query"],
        "positive": data["answer"],
    }

    for i, neg in enumerate(negatives):
        item[f"negative_{i}"] = neg
    return item



