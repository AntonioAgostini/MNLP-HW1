# Retrieving topk candidate chunks
def retrieve_top_k(sim_ladder, k, ds):
    topk = []

    id_to_item = {item["query_id"]: item for item in ds}

    for query_id, chunk_ids in sim_ladder.items():
        topk_chunks_id = chunk_ids[:k]
        topk_chunks = []

        for chunk_id in topk_chunks_id:
            topk_chunks.append(
                id_to_item[query_id]["candidate_chunks"][chunk_id]
            )

        data = {
            "query_id": query_id,
            "query": id_to_item[query_id]["query"],
            "topk_chunk_ids": topk_chunks_id,
            "candidate_chunks": topk_chunks,
        }
        topk.append(data)

    return topk

def convert_to_tsv(ds, _type, output_path):

    os.makedirs(os.path.dirname(output_path) or ".", exist_ok=True)

    with open(output_path, "w") as f:
        if _type == "queries":
            for example in ds:
                qid = example["query_id"]
                query = example["query"].replace("\t", " ").replace("\n", " ")
                f.write(f"{qid}\t{query}\n")

        elif _type == "collection":
            for example in ds:
                qid = example["query_id"]
                chunks = example["candidate_chunks"]
                chunk_ids = example["topk_chunk_ids"]

                for chunk_id, chunk in zip(chunk_ids, chunks):
                    pid = f"{qid}_{chunk_id}"
                    chunk = chunk.replace("\t", " ").replace("\n", " ")
                    f.write(f"{pid}\t{chunk}\n")

def write_topk_tsv(similarity_ladder, k, output_path):

     with open(output_path, "w") as f:
        for qid, ranked_chunk_ids in similarity_ladder.items():
            topk_chunk_ids = ranked_chunk_ids[:k]

            for rank, chunk_id in enumerate(topk_chunk_ids):
                pid = f"{qid}_{chunk_id}"
                f.write(f"{qid}\t{pid}\t{rank + 1}\n")

