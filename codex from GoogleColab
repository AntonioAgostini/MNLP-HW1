# RE-RANK TOP-K CANDIDATES WITH ColBERT
with Run().context(RunConfig(root=COLBERT_RUN_ROOT)):
    # Searcher that queries the previously built index
    searcher = Searcher(
        index=COLBERT_INDEX_NAME,
        config=colbert_config,
    )

    # Load all test queries from tsv file
    queries = Queries(f"{COLBERT_DATA_DIR}/queries.tsv")

    # colbert_rankings: dict {qid -> list of (pid, score)} sorted by ColBERT similarity
    colbert_rankings = searcher.search_all(
        queries,
        k=15,
    )

# CONVERT ColBERT RANKINGS INTO sim_ladder_reranked
sim_ladder_reranked = {} # sim_ladder_reranked has the same structure as st_test_sim_ladder: {query_id -> [chunk_id0, chunk_id1, ...]}

for qid, results in colbert_rankings.items():
    # 'results' is a list of (pid, score) tuples, ordered by ColBERT score
    # pid has the format "qid_chunkid" (e.g. "123_7"), so we can recover chunk_id
    chunk_ids = []
    for pid, score in results:
        # Extract the original chunk index from the passage id
        chunk_id = int(pid.split("_")[1])
        chunk_ids.append(chunk_id)

    sim_ladder_reranked[qid] = chunk_ids

def ranks_from_sim_ladder(sim_ladder, dataset):
    """
    Build the list of ranks for the correct answer for each query,
    given a similarity ladder (sim_ladder) and the original HF dataset.

    sim_ladder: dict {query_id -> [chunk_idx0, chunk_idx1, ...]} representing the ranking.
    dataset: HuggingFace split (e.g. ds["test"]) containing 'answer_pos' for each query.

    Returns:
        ranks: list of integer ranks (1-based), one per query.
    """
    # Map query_id to the full dataset example for fast lookup
    id_to_item = {item["query_id"]: item for item in dataset}
    ranks = []

    for qid, ranked_chunk_ids in sim_ladder.items():
        item = id_to_item[qid]
        correct_pos = int(item["answer_pos"])  # Ground-truth chunk index

        # Rank is the (1-based) position of the correct chunk in the ColBERT ranking
        rank = ranked_chunk_ids.index(correct_pos) + 1
        ranks.append(rank)

    return ranks


